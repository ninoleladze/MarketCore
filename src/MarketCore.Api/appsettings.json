{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3306;Database=MarketCoreDb;User=root;Password=root;",
    "Redis": "redis:6379"
  },
  "Jwt": {
    "Key": "REPLACE_WITH_A_32_CHARACTER_OR_LONGER_SECRET_KEY_IN_PRODUCTION",
    "Issuer": "MarketCore",
    "Audience": "MarketCoreClients",
    "ExpiryDays": 7
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {CorrelationId} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/marketcore-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {CorrelationId} {RequestId} {MachineName} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*",
  "AllowedOrigins": "http://localhost:4200,http://localhost:3000,https://market-core-client.vercel.app"
}
